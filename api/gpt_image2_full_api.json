{
  "name": "Vector GPT-Image-2 Full API",
  "description": "VectorEngine GPT-Image-2 edit API with behavior-focused parameters.",
  "gpt_image2_mode": "official",
  "endpoints": {
    "edit": "/v1/images/edits"
  },
  "hosts": {
    "china": "https://api.vectorengine.ai",
    "overseas": "https://api.zhongzhuan.vip",
    "custom": "https://api.vectorengine.ai"
  },
  "default_host": "china",
  "request_format": {
    "edit": {
      "method": "POST",
      "content_type": "multipart/form-data",
      "headers": {
        "Authorization": "Bearer {api_key}",
        "Accept": "application/json"
      },
      "body": {
        "model": "{model}",
        "prompt": "{prompt}",
        "n": "{n}",
        "size": "{size}",
        "quality": "{quality}",
        "moderation": "{moderation}",
        "user": "{user}"
      }
    }
  },
  "response_format": {
    "draw": {
      "image_url_path": "data[0].url",
      "b64_json_path": "data[0].b64_json",
      "success_indicator": "data"
    }
  },
  "models": [
    "gpt-image-2"
  ],
  "model_mapping": {},
  "image_sizes": [
    "auto",
    "1024x1024",
    "1536x1024",
    "1024x1536",
    "2048x2048",
    "2048x1152",
    "3840x2160",
    "2160x3840"
  ],
  "aspect_ratios": []
}
