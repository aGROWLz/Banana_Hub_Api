{
  "name": "VAI API",
  "description": "VAI API - 适配 nano-banana 模型命名并映射到 Gemini 模型",
  "endpoints": {
    "draw": "/v1beta/models/{model}:generateContent"
  },
  "hosts": {
    "china": "https://api.gpt.ge",
    "overseas": "https://api.gpt.ge",
    "custom": "https://api.gpt.ge"
  },
  "default_host": "china",
  "request_format": {
    "draw": {
      "method": "POST",
      "content_type": "application/json",
      "headers": {
        "x-goog-api-key": "{api_key}",
        "Content-Type": "application/json"
      },
      "body": {
        "contents": "{contents}",
        "generationConfig": {
          "responseModalities": ["TEXT", "IMAGE"],
          "imageConfig": {
            "aspectRatio": "{aspect_ratio}",
            "imageSize": "{image_size}"
          }
        }
      }
    }
  },
  "response_format": {
    "draw": {
      "inline_data_path": "candidates[0].content.parts",
      "success_indicator": "candidates"
    }
  },
  "models": [
    "nano-banana-2",
    "nano-banana-pro"
  ],
  "model_mapping": {
    "nano-banana-2": "gemini-3.1-flash-image",
    "nano-banana-pro": "gemini-3-pro-image-preview"
  },
  "image_sizes": ["1K", "2K", "4K"],
  "aspect_ratios": ["auto", "1:1", "16:9", "9:16", "4:3", "3:4", "3:2", "2:3", "5:4", "4:5", "21:9"]
}
