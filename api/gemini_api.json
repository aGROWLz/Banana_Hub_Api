{
  "name": "Vector Gemini Understanding API",
  "description": "VectorEngine Gemini image/video understanding API.",
  "endpoints": {
    "image_understanding": "/v1/chat/completions",
    "video_understanding": "/v1/chat/completions"
  },
  "hosts": {
    "china": "https://api.vectorengine.ai",
    "overseas": "https://api.zhongzhuan.vip",
    "custom": "https://api.vectorengine.ai"
  },
  "default_host": "china",
  "request_format": {
    "image_understanding": {
      "method": "POST",
      "content_type": "application/json",
      "headers": {
        "Authorization": "Bearer {api_key}",
        "Content-Type": "application/json"
      },
      "body": {
        "model": "{model}",
        "messages": "{messages}",
        "temperature": "{temperature}",
        "max_tokens": "{max_tokens}"
      }
    },
    "video_understanding": {
      "method": "POST",
      "content_type": "application/json",
      "headers": {
        "Authorization": "Bearer {api_key}",
        "Content-Type": "application/json"
      },
      "body": {
        "model": "{model}",
        "messages": "{messages}",
        "temperature": "{temperature}",
        "max_tokens": "{max_tokens}"
      }
    }
  },
  "response_format": {
    "image_understanding": {
      "text_content_path": "choices[0].message.content",
      "success_indicator": "choices"
    },
    "video_understanding": {
      "text_content_path": "choices[0].message.content",
      "success_indicator": "choices"
    }
  },
  "models": [
    "gemini-3.1-flash-lite"
  ],
  "model_mapping": {},
  "image_sizes": [],
  "aspect_ratios": []
}
