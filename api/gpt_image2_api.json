{
  "name": "Vector DALL-E 3 Image API",
  "description": "VectorEngine DALL-E 3 image generation API - 支持图片输入编辑",
  "gpt_image2_mode": "reverse",
  "endpoints": {
    "draw": "/v1/images/generations",
    "edit": "/v1/images/edits"
  },
  "hosts": {
    "china": "https://api.vectorengine.ai",
    "overseas": "https://api.zhongzhuan.vip",
    "custom": "https://api.vectorengine.ai"
  },
  "default_host": "china",
  "request_format": {
    "draw": {
      "method": "POST",
      "content_type": "multipart/form-data",
      "headers": {
        "Authorization": "Bearer {api_key}",
        "Accept": "application/json"
      },
      "body": {
        "model": "{model}",
        "prompt": "{prompt}",
        "n": "{n}"
      }
    },
    "edit": {
      "method": "POST",
      "content_type": "multipart/form-data",
      "headers": {
        "Authorization": "Bearer {api_key}",
        "Accept": "application/json"
      },
      "body": {
        "model": "{model}",
        "prompt": "{prompt}",
        "n": "{n}"
      }
    }
  },
  "response_format": {
    "draw": {
      "image_url_path": "data[0].url",
      "b64_json_path": "data[0].b64_json",
      "success_indicator": "data"
    }
  },
  "models": [
    "gpt-image-2-all"
  ],
  "model_mapping": {},
  "image_sizes": [
    "1024x1024",
    "1792x1024",
    "1024x1792"
  ],
  "aspect_ratios": []
}
