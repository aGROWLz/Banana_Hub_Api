{
  "name": "GPT-Image-2 Edit API",
  "description": "GPT-Image-2 图片编辑 API - 使用 bltai 域名（逆向分组）",
  "endpoints": {
    "draw": "/v1/images/edits"
  },
  "hosts": {
    "china": "https://api.bltcy.ai",
    "overseas": "https://api.gptbest.vip",
    "custom": "https://api.bltcy.ai"
  },
  "default_host": "china",
  "request_format": {
    "draw": {
      "method": "POST",
      "content_type": "multipart/form-data",
      "headers": {
        "Authorization": "Bearer {api_key}"
      },
      "body": {
        "model": "{model}",
        "prompt": "{prompt}",
        "size": "{size}",
        "image": "{image_files}"
      }
    }
  },
  "response_format": {
    "draw": {
      "image_url_path": "data[0].url",
      "b64_json_path": "data[0].b64_json",
      "success_indicator": "data"
    }
  },
  "models": [
    "gpt-image-2"
  ],
  "model_mapping": {},
  "image_sizes": ["auto", "1024x1024", "1536x1024", "1024x1536", "2048x2048", "2048x1152", "3840x2160", "2160x3840"],
  "aspect_ratios": []
}
